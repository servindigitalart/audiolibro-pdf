---
import BaseLayout from './BaseLayout.astro';
import Nav from '@/components/marketing/Nav.astro';
import Footer from '@/components/marketing/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
---

<BaseLayout {title} {description} {ogImage} {canonical}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
