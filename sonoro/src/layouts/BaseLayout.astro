---
import '@/styles/globals.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title = 'Sonoro – Turn PDFs into Audiobooks Instantly',
  description = 'Convert any PDF into a professional audiobook in seconds. Perfect for students, professionals, and lifelong learners. Try free.',
  ogImage = '/og.png',
  canonical,
  noIndex = false,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://sonoro.app';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FDFCFB" />

    <!-- Inter font — preconnect + async load (no render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      id="font-inter"
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      media="all"
    />
    <!-- Progressively load: initially apply print media so it doesn't block render -->
    <script is:inline>
      (function(){var l=document.getElementById('font-inter');if(l){l.media='print';l.onload=function(){l.media='all';l.onload=null;}}})();
    </script>

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${appUrl}${ogImage}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${appUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Sonoro",
        "applicationCategory": "ProductivityApplication",
        "operatingSystem": "Web",
        "description": description,
        "url": appUrl,
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      })}
    </script>
  </head>

  <body class="bg-sonoro-white text-sonoro-900 antialiased">
    <slot />

    <!-- Scroll reveal observer — GPU-composited, stagger-aware -->
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(function (el) { observer.observe(el); });
      })();
    </script>
  </body>
</html>
