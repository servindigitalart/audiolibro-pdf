---
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
---

<header class="fixed top-0 inset-x-0 z-50">
  <!-- Frosted glass backdrop -->
  <div class="absolute inset-0 bg-sonoro-white/80 backdrop-blur-xl border-b border-sonoro-border/60"></div>

  <nav class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Sonoro home">
      <SonoroLogo class="h-7 w-7" />
      <span class="text-xl font-bold tracking-tight text-sonoro-900 group-hover:text-sonoro-amber transition-colors">
        Sonoro
      </span>
    </a>

    <!-- Center links -->
    <ul class="hidden md:flex items-center gap-1">
      {[
        { href: '/#features', label: 'Features' },
        { href: '/pricing',   label: 'Pricing'  },
        { href: '/#how',      label: 'How it works' },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="px-4 py-2 rounded-full text-sm text-sonoro-600 hover:text-sonoro-900 hover:bg-sonoro-surface transition-all duration-150"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <a href="/login" class="hidden sm:block text-sm text-sonoro-600 hover:text-sonoro-900 transition-colors px-3 py-2">
        Sign in
      </a>
      <a href="/register" class="btn-primary btn-sm !px-5 !py-2 text-sm">
        Get started free
      </a>
    </div>
  </nav>
</header>

<!-- Spacer for fixed nav -->
<div class="h-[72px]"></div>
