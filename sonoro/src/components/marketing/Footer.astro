---
import SonoroLogo from '@/components/ui/SonoroLogo.astro';

const links = {
  Product: [
    { label: 'Features',   href: '/#features' },
    { label: 'Pricing',    href: '/pricing'    },
    { label: 'How it works', href: '/#how'     },
  ],
  Company: [
    { label: 'About',    href: '/about'   },
    { label: 'Blog',     href: '/blog'    },
    { label: 'Careers',  href: '/careers' },
  ],
  Support: [
    { label: 'Help center',  href: '/help'    },
    { label: 'Contact',      href: '/contact' },
    { label: 'Status',       href: '/status'  },
  ],
  Legal: [
    { label: 'Privacy',  href: '/privacy' },
    { label: 'Terms',    href: '/terms'   },
    { label: 'Security', href: '/security'},
  ],
};
---

<footer class="bg-sonoro-surface border-t border-sonoro-border">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">

    <!-- Top row -->
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-3 group">
          <SonoroLogo class="h-7 w-7" />
          <span class="text-lg font-bold text-sonoro-900 group-hover:text-sonoro-amber transition-colors">Sonoro</span>
        </a>
        <p class="text-sm text-sonoro-muted leading-relaxed max-w-xs">
          Turn any PDF into a professional audiobook. Built for learners who move fast.
        </p>
      </div>

      <!-- Link groups -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <p class="label-sm mb-4">{group}</p>
          <ul class="space-y-2.5">
            {items.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm text-sonoro-600 hover:text-sonoro-900 transition-colors">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-sonoro-border">
      <p class="text-xs text-sonoro-muted">
        &copy; {new Date().getFullYear()} Sonoro. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://twitter.com" class="text-sonoro-muted hover:text-sonoro-900 transition-colors" aria-label="Twitter">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://linkedin.com" class="text-sonoro-muted hover:text-sonoro-900 transition-colors" aria-label="LinkedIn">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>
