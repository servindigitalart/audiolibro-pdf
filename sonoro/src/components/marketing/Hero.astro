---
// Deterministic values — never Math.random() inside components (SSR/client mismatch)
const WAVE_H = [38, 72, 54, 91, 63, 46, 82, 58, 77, 50, 86, 41, 68, 88, 57, 74, 44, 79, 62, 70];
const WAVE_D = [0, 0.15, 0.30, 0.45, 0.60, 0.10, 0.25, 0.50, 0.08, 0.35, 0.55, 0.20, 0.40, 0.05, 0.65, 0.18, 0.42, 0.28, 0.70, 0.12];
---

<section class="relative overflow-hidden bg-sonoro-white">
  <!-- Very subtle grid — 64px cells, very low opacity -->
  <div class="absolute inset-0 bg-grid pointer-events-none" aria-hidden="true"></div>

  <!-- Primary ambient glow — slow float -->
  <div
    class="absolute -top-32 left-1/2 -translate-x-1/2 w-[900px] h-[560px] glow-orb animate-glow-pulse pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(254,243,199,0.7) 0%, rgba(245,158,11,0.08) 45%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Side depth glow -->
  <div
    class="absolute top-1/4 -right-32 w-[480px] h-[480px] glow-orb opacity-[0.07] animate-float-delayed pointer-events-none"
    style="background: radial-gradient(ellipse, #F59E0B 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-6 pt-16 pb-20 text-center lg:px-8 lg:pt-20 lg:pb-28">

    <!-- Eyebrow badge -->
    <div class="animate-fade-in" style="animation-delay:0s">
      <span class="inline-flex items-center gap-2 rounded-full border border-sonoro-amber/25 bg-gradient-to-r from-sonoro-amber-light/70 to-sonoro-amber-light/40 px-4 py-1.5 text-xs font-semibold text-sonoro-amber-dark mb-8">
        <span class="flex h-1.5 w-1.5 rounded-full bg-sonoro-amber animate-pulse" aria-hidden="true"></span>
        AI-powered PDF to audiobook
      </span>
    </div>

    <!-- Headline — identity-driven, emotionally specific -->
    <h1
      class="heading-display text-display-xl md:text-display-2xl text-balance mx-auto max-w-[14ch] animate-slide-up"
      style="animation-delay:0.08s"
    >
      Stop falling behind<br />on what&nbsp;<span class="gradient-text-amber">matters.</span>
    </h1>

    <!-- Subheadline — outcome-focused, specific -->
    <p
      class="mt-6 text-lg leading-relaxed text-sonoro-600 max-w-[42ch] mx-auto text-balance animate-slide-up"
      style="animation-delay:0.16s"
    >
      Upload any PDF. Sonoro converts it into studio-quality audio in 60&nbsp;seconds.
      Listen on your commute, your run, your lunch break.
    </p>

    <!-- CTAs -->
    <div
      class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3 animate-slide-up"
      style="animation-delay:0.24s"
    >
      <a href="/register" class="btn-accent btn-lg" data-event="hero_cta_click">
        Start free — no card needed
        <svg class="w-4 h-4 ml-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/#how" class="btn-ghost btn-lg text-sonoro-500 hover:text-sonoro-700">
        See how it works
      </a>
    </div>

    <!-- Social proof cluster -->
    <div
      class="mt-8 flex items-center justify-center gap-4 animate-fade-in"
      style="animation-delay:0.38s"
    >
      <div class="flex -space-x-2" aria-hidden="true">
        {(['SK','MR','PM','JT'] as const).map((initials, i) => (
          <div
            class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-sonoro-white bg-sonoro-amber-light text-[9px] font-bold text-sonoro-amber-dark shadow-soft"
            style={`z-index:${4-i}`}
          >{initials}</div>
        ))}
      </div>
      <p class="text-sm text-sonoro-500">
        Trusted by <strong class="text-sonoro-700 font-semibold">2,400+</strong> learners worldwide
      </p>
    </div>

    <!-- Product mockup -->
    <div class="mt-16 mx-auto max-w-xl reveal" style="transition-delay:0.12s">
      <div class="relative">
        <!-- Warm shadow behind card -->
        <div
          class="absolute inset-x-10 -bottom-4 h-20 blur-2xl pointer-events-none"
          style="background: linear-gradient(135deg, rgba(245,158,11,0.22), rgba(251,191,36,0.15));"
          aria-hidden="true"
        ></div>

        <div class="relative card-base p-6 text-left shadow-modal">
          <!-- File header -->
          <div class="flex items-center gap-3 mb-5 pb-5 border-b border-sonoro-border">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-50 border border-red-100 shrink-0">
              <svg class="w-5 h-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-sonoro-900 truncate">Thinking_Fast_and_Slow.pdf</p>
              <p class="text-xs text-sonoro-muted mt-0.5">437 pages · 2.1 MB</p>
            </div>
            <span class="badge badge-success shrink-0">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
              Ready
            </span>
          </div>

          <!-- Player -->
          <p class="label-sm mb-3">Now playing</p>
          <p class="text-sm font-semibold text-sonoro-900 mb-4">Part II — Heuristics and Biases</p>

          <!-- Waveform — deterministic -->
          <div class="flex items-end gap-0.5 h-9 mb-4" aria-hidden="true">
            {WAVE_H.map((h, i) => (
              <div
                class="waveform-bar flex-1"
                style={`height:${h}%;animation-delay:${WAVE_D[i]}s`}
              ></div>
            ))}
          </div>

          <!-- Scrub -->
          <div class="flex items-center gap-3">
            <span class="text-xs tabular text-sonoro-muted">08:23</span>
            <div class="flex-1 h-1.5 rounded-full bg-sonoro-border overflow-hidden">
              <div class="h-full w-[31%] rounded-full bg-sonoro-amber" style="background: linear-gradient(90deg,#D97706,#F59E0B)"></div>
            </div>
            <span class="text-xs tabular text-sonoro-muted">26:47</span>
          </div>

          <!-- Controls -->
          <div class="flex items-center justify-between mt-5">
            <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-sonoro-surface text-sonoro-600 border border-sonoro-border">1×</span>
            <div class="flex items-center gap-5">
              <button class="text-sonoro-300" aria-label="Previous chapter">
                <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M4 5h2v10H4V5zm3.586 4.408L13 5.587A1 1 0 0115 6.179v7.642a1 1 0 01-1.414.908l-5.414-3.22a1 1 0 010-1.101z"/>
                </svg>
              </button>
              <button class="flex h-10 w-10 items-center justify-center rounded-full bg-sonoro-black text-sonoro-white shadow-card" aria-label="Pause">
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M5 4h3v12H5V4zm7 0h3v12h-3V4z"/>
                </svg>
              </button>
              <button class="text-sonoro-300" aria-label="Next chapter">
                <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M16 5h-2v10h2V5zm-9 .587A1 1 0 005 6.179v7.642a1 1 0 001.414.908l5.414-3.22a1 1 0 000-1.101L7 5.587z"/>
                </svg>
              </button>
            </div>
            <span class="text-xs tabular text-sonoro-muted">3 / 12</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
