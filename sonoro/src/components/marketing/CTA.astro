---
---
<section class="section-padding bg-sonoro-black text-sonoro-white overflow-hidden relative">
  <!-- Decorative glow -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-20 blur-3xl pointer-events-none"
    style="background: radial-gradient(ellipse at center, #F59E0B 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-3xl px-6 text-center lg:px-8">
    <div class="flex items-center justify-center gap-1.5 mb-4">
      {Array.from({ length: 5 }).map(() => (
        <svg class="w-4 h-4 text-sonoro-amber" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      ))}
    </div>

    <h2 class="text-display-lg md:text-display-xl font-bold tracking-tight text-balance">
      Your reading list is waiting.<br />Start listening today.
    </h2>

    <p class="mt-5 text-sonoro-400 text-lg leading-relaxed max-w-lg mx-auto">
      Join 2,400+ professionals and students who've made Sonoro part of their learning routine.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/register"
        class="inline-flex items-center gap-2 rounded-full bg-sonoro-amber px-8 py-3.5 text-sm font-semibold text-sonoro-black hover:bg-sonoro-amber-dark transition-all duration-150 active:scale-[0.98] shadow-hover"
      >
        Get started — it's free
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="/pricing"
        class="text-sm text-sonoro-400 hover:text-sonoro-white transition-colors underline-offset-4 hover:underline"
      >
        View pricing →
      </a>
    </div>

    <p class="mt-6 text-xs text-sonoro-600">
      No credit card · Free forever tier · Cancel anytime
    </p>
  </div>
</section>
