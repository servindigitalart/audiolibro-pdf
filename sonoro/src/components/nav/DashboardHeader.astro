---
import type { User } from '@/lib/api/types';

export interface Props {
  user: User | null;
}
const { user } = Astro.props;
const initials = user?.email?.charAt(0).toUpperCase() ?? '?';
---

<header class="flex items-center justify-between border-b border-sonoro-border bg-sonoro-white px-6 shrink-0 h-[60px]">

  <!-- Mobile logo -->
  <a href="/dashboard" class="md:hidden font-bold text-sonoro-900 text-[1.0625rem] tracking-tight">Sonoro</a>

  <!-- Left slot — breadcrumb placeholder (pages can override via portal if needed) -->
  <div class="hidden md:block" id="breadcrumb-slot"></div>

  <!-- Right actions -->
  <div class="flex items-center gap-3 ml-auto">

    <!-- Upload CTA -->
    <a href="/dashboard/upload" class="btn-primary btn-sm hidden sm:inline-flex gap-1.5">
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 2v9m-4-4 4-4 4 4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Upload
    </a>

    <!-- User menu -->
    {user ? (
      <div class="relative group">
        <button
          class="flex h-8 w-8 items-center justify-center rounded-full bg-sonoro-amber-light text-xs font-bold text-sonoro-amber-dark ring-2 ring-transparent hover:ring-sonoro-amber/30 transition-all duration-150"
          aria-label="User menu"
          aria-haspopup="true"
        >
          {initials}
        </button>

        <!-- Dropdown -->
        <div
          class="absolute right-0 top-[calc(100%+8px)] w-48 rounded-2xl border border-sonoro-border bg-sonoro-white shadow-modal opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 overflow-hidden"
          role="menu"
        >
          <!-- User info -->
          <div class="px-4 py-3 border-b border-sonoro-border bg-sonoro-surface/60">
            <p class="text-xs font-semibold text-sonoro-900 truncate">{user.email}</p>
            <p class="text-[10px] text-sonoro-muted mt-0.5 font-medium">{user.plan_tier} plan</p>
          </div>

          <div class="py-1.5">
            <a href="/dashboard" class="flex items-center gap-2.5 px-4 py-2 text-xs text-sonoro-700 hover:bg-sonoro-surface hover:text-sonoro-900 transition-colors" role="menuitem">
              <svg class="w-3.5 h-3.5 text-sonoro-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8z"/><path d="M8 4a.75.75 0 01.75.75V8.5h2a.75.75 0 010 1.5h-2.75A.75.75 0 017.25 9.25V4.75A.75.75 0 018 4z"/></svg>
              Dashboard
            </a>
            <a href="/dashboard/settings" class="flex items-center gap-2.5 px-4 py-2 text-xs text-sonoro-700 hover:bg-sonoro-surface hover:text-sonoro-900 transition-colors" role="menuitem">
              <svg class="w-3.5 h-3.5 text-sonoro-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.429 1.525a6.593 6.593 0 011.142 0c.036.003.108.036.137.146l.289 1.105c.147.56.55.967.997 1.189.174.086.341.183.501.29.417.278.97.423 1.53.27l1.102-.303c.108-.03.175.019.199.046.236.274.45.567.641.875.192.308.358.633.495.973.037.096.01.172-.023.198l-.84.732c-.433.377-.556.899-.434 1.361v.002c.06.226.09.46.09.7 0 .24-.03.473-.09.699-.122.462.001.984.434 1.361l.84.732c.033.026.06.102.023.198a7.176 7.176 0 01-1.136 1.848c-.024.027-.091.075-.199.046l-1.103-.303c-.559-.153-1.112-.008-1.529.27-.16.107-.327.204-.5.29-.449.222-.851.628-.998 1.189l-.289 1.105c-.029.11-.101.143-.137.146a6.613 6.613 0 01-1.142 0c-.036-.003-.108-.037-.137-.146l-.289-1.105c-.147-.56-.55-.967-.997-1.189a5.078 5.078 0 01-.501-.29c-.417-.278-.97-.423-1.53-.27l-1.102.303c-.108.03-.175-.019-.199-.046a7.176 7.176 0 01-1.136-1.848c-.037-.096-.01-.172.023-.198l.84-.732c.433-.377.556-.899.434-1.361A3.458 3.458 0 012 8c0-.24.03-.474.09-.7.122-.462-.001-.984-.434-1.361l-.84-.732c-.033-.026-.06-.102-.023-.198a7.175 7.175 0 011.136-1.848c.024-.027.091-.075.199-.046l1.103.303c.559.153 1.112.008 1.529-.27.16-.107.327-.204.5-.29.449-.222.851-.628.998-1.189l.289-1.105c.029-.11.101-.143.137-.146zM8 11a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
              Settings
            </a>
            <a href="/dashboard/billing" class="flex items-center gap-2.5 px-4 py-2 text-xs text-sonoro-700 hover:bg-sonoro-surface hover:text-sonoro-900 transition-colors" role="menuitem">
              <svg class="w-3.5 h-3.5 text-sonoro-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2 4a2 2 0 012-2h8a2 2 0 012 2H2zm0 2h12v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6zm7 5a1 1 0 100-2 1 1 0 000 2z"/></svg>
              Billing
            </a>
          </div>

          <div class="border-t border-sonoro-border py-1.5">
            <form method="POST" action="/api/logout">
              <button
                type="submit"
                class="flex w-full items-center gap-2.5 px-4 py-2 text-xs text-red-600 hover:bg-red-50 transition-colors"
                role="menuitem"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 3.75a.75.75 0 01.75-.75h.5A2.75 2.75 0 0114 5.75v4.5A2.75 2.75 0 0111.25 13h-.5a.75.75 0 010-1.5h.5c.69 0 1.25-.56 1.25-1.25v-4.5c0-.69-.56-1.25-1.25-1.25h-.5A.75.75 0 0110 3.75zm-5.03 4.78a.75.75 0 00-1.06-1.06l-2.5 2.5a.75.75 0 000 1.06l2.5 2.5a.75.75 0 101.06-1.06l-1.22-1.22h6.5a.75.75 0 000-1.5H3.75l1.22-1.22z" clip-rule="evenodd"/></svg>
                Sign out
              </button>
            </form>
          </div>
        </div>
      </div>
    ) : (
      <a href="/login" class="btn-outline btn-sm">Sign in</a>
    )}
  </div>
</header>
