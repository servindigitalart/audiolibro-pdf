---
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
import type { User, AccountOverview } from '@/lib/api/types';
import { pct } from '@/lib/utils';

export interface Props {
  activeNav: string;
  user: User | null;
  usage: AccountOverview['usage'] | null;
}

const { activeNav, user, usage } = Astro.props;

const navItems = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    href: '/dashboard',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>`,
  },
  {
    id: 'documents',
    label: 'My Library',
    href: '/dashboard/documents',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>`,
  },
  {
    id: 'upload',
    label: 'Upload PDF',
    href: '/dashboard/upload',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM6.293 6.707a1 1 0 010-1.414l3-3a1 1 0 011.414 0l3 3a1 1 0 01-1.414 1.414L11 5.414V13a1 1 0 11-2 0V5.414L7.707 6.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>`,
    accent: true,
  },
  {
    id: 'billing',
    label: 'Billing',
    href: '/dashboard/billing',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/></svg>`,
  },
  {
    id: 'settings',
    label: 'Settings',
    href: '/dashboard/settings',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>`,
  },
];

const charPct   = usage ? pct(usage.chars_used, usage.chars_limit) : 0;
const charColor = charPct >= 100 ? 'bg-red-500' : charPct >= 80 ? 'bg-amber-500' : 'bg-emerald-500';
const tier      = user?.plan_tier ?? 'FREE';
const initials  = user?.email?.charAt(0).toUpperCase() ?? '?';
const isFreePlan = tier === 'FREE';
---

<aside class="hidden md:flex flex-col w-60 shrink-0 border-r border-sonoro-border bg-sonoro-white h-full">

  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-5 h-[60px] border-b border-sonoro-border shrink-0">
    <a href="/dashboard" class="flex items-center gap-2.5 group">
      <SonoroLogo class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" />
      <span class="text-[1.0625rem] font-bold tracking-tight text-sonoro-900">Sonoro</span>
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-px overflow-y-auto" aria-label="Main navigation">
    {navItems.map(({ id, label, href, icon, accent }) => {
      const active = activeNav === id;
      return (
        <a
          href={href}
          class:list={[
            'group relative flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150',
            active
              ? 'bg-sonoro-surface text-sonoro-900'
              : accent
                ? 'text-sonoro-600 hover:text-sonoro-900 hover:bg-sonoro-amber-light/40'
                : 'text-sonoro-600 hover:text-sonoro-900 hover:bg-sonoro-surface',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          <!-- Active left bar -->
          <span
            class:list={[
              'absolute left-0 inset-y-2.5 w-0.5 rounded-full transition-all duration-200',
              active ? 'bg-sonoro-amber opacity-100' : 'bg-sonoro-amber opacity-0 group-hover:opacity-30',
            ]}
            aria-hidden="true"
          />

          <!-- Icon -->
          <span
            class:list={[
              'shrink-0 transition-colors duration-150',
              active
                ? 'text-sonoro-amber-dark'
                : accent
                  ? 'text-sonoro-amber-dark/70 group-hover:text-sonoro-amber-dark'
                  : 'text-sonoro-400 group-hover:text-sonoro-600',
            ]}
            set:html={icon}
          />

          <span class="flex-1">{label}</span>

          <!-- Upload badge -->
          {accent && !active && (
            <span
              class="flex h-5 w-5 items-center justify-center rounded-full bg-sonoro-amber text-sonoro-black text-[10px] font-bold shadow-amber transition-transform duration-150 group-hover:scale-110"
              aria-hidden="true"
            >+</span>
          )}
        </a>
      );
    })}
  </nav>

  <!-- Usage meter -->
  {usage && (
    <div class="px-4 py-4 border-t border-sonoro-border space-y-2.5">
      <div class="flex items-center justify-between">
        <p class="text-xs text-sonoro-muted">Monthly quota</p>
        <p class:list={['text-xs font-semibold tabular', charPct >= 80 ? 'text-amber-600' : 'text-sonoro-700']}>
          {Math.round(charPct)}%
        </p>
      </div>
      <div class="h-1 w-full rounded-full bg-sonoro-border overflow-hidden">
        <div
          class:list={['h-full rounded-full transition-all duration-700', charColor]}
          style={`width:${Math.min(charPct, 100)}%`}
        />
      </div>
      <p class="text-[10px] text-sonoro-400 tabular">
        {usage.chars_used.toLocaleString()} / {usage.chars_limit.toLocaleString()} chars
      </p>
      {isFreePlan && (
        <a
          href="/dashboard/billing"
          class="flex items-center justify-between w-full rounded-xl bg-sonoro-surface border border-sonoro-border px-3 py-2 hover:border-sonoro-amber/40 hover:bg-sonoro-amber-light/20 transition-all duration-150 group"
        >
          <span class="text-xs font-medium text-sonoro-700 group-hover:text-sonoro-900">Upgrade plan</span>
          <svg class="w-3.5 h-3.5 text-sonoro-400 group-hover:text-sonoro-amber-dark transition-colors" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 7h8M7 3l4 4-4 4"/>
          </svg>
        </a>
      )}
    </div>
  )}

  <!-- User card -->
  {user && (
    <div class="px-4 py-4 border-t border-sonoro-border">
      <div class="flex items-center gap-3">
        <!-- Avatar -->
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-sonoro-amber-light to-amber-200 text-xs font-bold text-sonoro-amber-dark ring-2 ring-white">
          {initials}
        </div>
        <!-- Info -->
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-sonoro-900 truncate leading-none mb-1">{user.email}</p>
          <span class:list={[
            'inline-flex items-center text-[10px] font-semibold px-1.5 py-0.5 rounded-full leading-none',
            isFreePlan
              ? 'text-sonoro-500 bg-sonoro-surface border border-sonoro-border'
              : 'text-amber-800 bg-gradient-to-r from-amber-100 to-amber-200 border border-amber-200',
          ]}>
            {tier}
          </span>
        </div>
        <!-- Settings shortcut -->
        <a
          href="/dashboard/settings"
          class="flex h-6 w-6 shrink-0 items-center justify-center rounded-lg text-sonoro-300 hover:text-sonoro-600 hover:bg-sonoro-surface transition-colors"
          aria-label="Settings"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M7.429 1.525a6.593 6.593 0 011.142 0c.036.003.108.036.137.146l.289 1.105c.147.56.55.967.997 1.189.174.086.341.183.501.29.417.278.97.423 1.53.27l1.102-.303c.108-.03.175.019.199.046.236.274.45.567.641.875.192.308.358.633.495.973.037.096.01.172-.023.198l-.84.732c-.433.377-.556.899-.434 1.361v.002c.06.226.09.46.09.7 0 .24-.03.473-.09.699-.122.462.001.984.434 1.361l.84.732c.033.026.06.102.023.198a7.176 7.176 0 01-1.136 1.848c-.024.027-.091.075-.199.046l-1.103-.303c-.559-.153-1.112-.008-1.529.27-.16.107-.327.204-.5.29-.449.222-.851.628-.998 1.189l-.289 1.105c-.029.11-.101.143-.137.146a6.613 6.613 0 01-1.142 0c-.036-.003-.108-.037-.137-.146l-.289-1.105c-.147-.56-.55-.967-.997-1.189a5.078 5.078 0 01-.501-.29c-.417-.278-.97-.423-1.53-.27l-1.102.303c-.108.03-.175-.019-.199-.046a7.176 7.176 0 01-1.136-1.848c-.037-.096-.01-.172.023-.198l.84-.732c.433-.377.556-.899.434-1.361A3.458 3.458 0 012 8c0-.24.03-.474.09-.7.122-.462-.001-.984-.434-1.361l-.84-.732c-.033-.026-.06-.102-.023-.198a7.175 7.175 0 011.136-1.848c.024-.027.091-.075.199-.046l1.103.303c.559.153 1.112.008 1.529-.27.16-.107.327-.204.5-.29.449-.222.851-.628.998-1.189l.289-1.105c.029-.11.101-.143.137-.146zM8 11a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  )}
</aside>
