---
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
import type { User, AccountOverview } from '@/lib/api/types';
import { pct } from '@/lib/utils';

export interface Props {
  activeNav: string;
  user: User | null;
  usage: AccountOverview['usage'] | null;
}

const { activeNav, user, usage } = Astro.props;

const navItems = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    href: '/dashboard',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>`,
  },
  {
    id: 'documents',
    label: 'My Library',
    href: '/dashboard/documents',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>`,
  },
  {
    id: 'upload',
    label: 'Upload PDF',
    href: '/dashboard/upload',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM6.293 6.707a1 1 0 010-1.414l3-3a1 1 0 011.414 0l3 3a1 1 0 01-1.414 1.414L11 5.414V13a1 1 0 11-2 0V5.414L7.707 6.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>`,
  },
  {
    id: 'billing',
    label: 'Billing',
    href: '/dashboard/billing',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/></svg>`,
  },
  {
    id: 'settings',
    label: 'Settings',
    href: '/dashboard/settings',
    icon: `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>`,
  },
];

const charPct = usage ? pct(usage.chars_used, usage.chars_limit) : 0;
const charColor = charPct >= 100 ? 'bg-red-500' : charPct >= 80 ? 'bg-amber-500' : 'bg-green-500';
const tier = user?.plan_tier ?? 'FREE';
---

<aside class="hidden md:flex flex-col w-60 shrink-0 border-r border-sonoro-border bg-sonoro-white h-full">
  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-5 py-5 border-b border-sonoro-border">
    <SonoroLogo class="h-7 w-7" />
    <span class="text-lg font-bold text-sonoro-900">Sonoro</span>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto" aria-label="Main navigation">
    {navItems.map(({ id, label, href, icon }) => {
      const active = activeNav === id;
      return (
        <a
          href={href}
          class:list={[
            'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-100',
            active
              ? 'bg-sonoro-surface text-sonoro-900 font-semibold'
              : 'text-sonoro-600 hover:text-sonoro-900 hover:bg-sonoro-surface/60',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          <div class:list={['w-4 h-4 shrink-0', active ? 'text-sonoro-amber-dark' : '']} set:html={icon}></div>
          {label}
          {id === 'upload' && (
            <span class="ml-auto flex h-5 w-5 items-center justify-center rounded-full bg-sonoro-black text-sonoro-white text-[10px] font-bold">+</span>
          )}
        </a>
      );
    })}
  </nav>

  <!-- Usage meter -->
  {usage && (
    <div class="px-4 py-4 border-t border-sonoro-border">
      <div class="flex items-center justify-between mb-1.5">
        <p class="text-xs text-sonoro-muted">Characters used</p>
        <p class="text-xs font-medium text-sonoro-700">{Math.round(charPct)}%</p>
      </div>
      <div class="h-1.5 w-full rounded-full bg-sonoro-border overflow-hidden mb-2">
        <div class:list={['h-full rounded-full transition-all duration-500', charColor]} style={`width: ${Math.min(charPct, 100)}%`}></div>
      </div>
      <p class="text-[10px] text-sonoro-muted">
        {usage.chars_used.toLocaleString()} / {usage.chars_limit.toLocaleString()} chars
      </p>
      {tier !== 'ENTERPRISE' && (
        <a href="/dashboard/billing" class="mt-3 block text-center text-xs font-semibold text-sonoro-amber-dark hover:text-sonoro-amber transition-colors">
          Upgrade plan →
        </a>
      )}
    </div>
  )}

  <!-- User -->
  {user && (
    <div class="px-4 py-4 border-t border-sonoro-border">
      <div class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sonoro-amber-light text-xs font-bold text-sonoro-amber-dark shrink-0">
          {user.email.charAt(0).toUpperCase()}
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-sonoro-900 truncate">{user.email}</p>
          <p class="text-[10px] text-sonoro-muted">{tier}</p>
        </div>
      </div>
    </div>
  )}
</aside>
