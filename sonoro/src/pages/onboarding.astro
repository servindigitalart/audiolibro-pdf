---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
import UploadZone from '@/components/upload/UploadZone';
import { fetchAccountOverview } from '@/lib/api/server';

const token   = (Astro.locals as any).token as string;
const overview = await fetchAccountOverview(token).catch(() => null);
if (!overview) return Astro.redirect('/login');

const step = parseInt(Astro.url.searchParams.get('step') ?? '1');
const clampedStep = Math.min(Math.max(step, 1), 3);
---

<BaseLayout title="Get started – Sonoro" noIndex={true}>
  <div class="min-h-screen bg-sonoro-surface flex flex-col">

    <!-- Progress bar -->
    <div class="h-1 bg-sonoro-border">
      <div
        class="h-full bg-sonoro-amber transition-all duration-500 ease-out"
        style={`width: ${(clampedStep / 3) * 100}%`}
        role="progressbar"
        aria-valuenow={clampedStep}
        aria-valuemin={1}
        aria-valuemax={3}
      ></div>
    </div>

    <!-- Header -->
    <header class="flex items-center justify-between px-8 py-5">
      <a href="/" class="flex items-center gap-2.5">
        <SonoroLogo class="h-7 w-7" />
        <span class="text-lg font-bold text-sonoro-900">Sonoro</span>
      </a>
      <div class="flex items-center gap-3">
        <span class="text-xs text-sonoro-muted">Step {clampedStep} of 3</span>
        <a href="/dashboard" class="btn-ghost btn-sm text-xs">Skip →</a>
      </div>
    </header>

    <!-- Content -->
    <main class="flex flex-1 flex-col items-center justify-center px-6 py-12">
      <div class="w-full max-w-xl">

        {clampedStep === 1 && (
          <div class="text-center animate-fade-in">
            <div class="flex items-end justify-center gap-1.5 h-14 mb-6">
              {[40, 70, 100, 80, 55, 90, 65].map((h, i) => (
                <div class="waveform-bar w-2" style={`height: ${h}%; animation-delay: ${i * 0.12}s;`}></div>
              ))}
            </div>
            <h1 class="text-2xl font-bold text-sonoro-900 mb-2">
              Welcome to Sonoro, {overview.user.email.split('@')[0]} 👋
            </h1>
            <p class="text-sm text-sonoro-600 mb-8 max-w-sm mx-auto">
              You're 60 seconds away from listening to your first audiobook. Let's go.
            </p>
            <a
              href="/onboarding?step=2"
              class="btn-accent btn-lg inline-flex"
            >
              Get started →
            </a>
          </div>
        )}

        {clampedStep === 2 && (
          <div class="animate-slide-up">
            <div class="text-center mb-8">
              <span class="label-sm text-sonoro-amber-dark block mb-3">Step 2 of 3</span>
              <h1 class="text-2xl font-bold text-sonoro-900 mb-2">Upload your first PDF</h1>
              <p class="text-sm text-sonoro-600">
                Any PDF works — textbook, report, paper, or novel.
              </p>
            </div>
            <UploadZone client:load />
            <p class="text-center mt-4 text-xs text-sonoro-muted">
              You can skip this and{' '}
              <a href="/onboarding?step=3" class="underline hover:text-sonoro-900 transition-colors">upload later →</a>
            </p>
          </div>
        )}

        {clampedStep === 3 && (
          <div class="text-center animate-fade-in">
            <div class="flex h-20 w-20 items-center justify-center rounded-3xl bg-green-50 border border-green-100 mx-auto mb-6">
              <svg class="w-10 h-10 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h1 class="text-2xl font-bold text-sonoro-900 mb-2">You're all set!</h1>
            <p class="text-sm text-sonoro-600 mb-8 max-w-sm mx-auto">
              Your account is ready. Head to your dashboard to manage your audiobooks.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/dashboard" class="btn-accent btn-lg">Go to dashboard →</a>
              <a href="/dashboard/upload" class="btn-outline btn-lg">Upload another PDF</a>
            </div>

            <!-- Quick tips -->
            <div class="mt-10 text-left rounded-2xl border border-sonoro-border bg-sonoro-white p-5 space-y-3">
              <p class="text-xs font-semibold text-sonoro-900 mb-3">Pro tips to get more out of Sonoro</p>
              {[
                { icon: '⚡', tip: 'Use 1.5× speed to get through material 50% faster.' },
                { icon: '📋', tip: 'Chapter detection means you can skip straight to what matters.' },
                { icon: '📥', tip: 'Download the MP3 for offline listening on commutes.' },
                { icon: '🔔', tip: "We'll email you when your conversion is ready." },
              ].map(({ icon, tip }) => (
                <div class="flex items-start gap-3">
                  <span class="text-base shrink-0">{icon}</span>
                  <p class="text-xs text-sonoro-600 leading-relaxed">{tip}</p>
                </div>
              ))}
            </div>
          </div>
        )}

      </div>
    </main>
  </div>
</BaseLayout>
