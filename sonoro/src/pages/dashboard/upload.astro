---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import UploadZone from '@/components/upload/UploadZone';
---

<DashboardLayout title="Upload PDF – Sonoro" activeNav="upload">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-sonoro-900 mb-1">Upload a PDF</h1>
      <p class="text-sm text-sonoro-muted">
        Drop your file and we'll convert it to a natural-sounding audiobook in under 60 seconds.
      </p>
    </div>

    <!-- Upload zone — React island -->
    <UploadZone client:load />

    <!-- Tips -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        { icon: '📏', title: 'Up to 100 MB',   body: 'Any PDF up to 100 MB and 500 pages.' },
        { icon: '🌍', title: 'Any language',   body: 'English optimized; other languages supported.' },
        { icon: '🔒', title: 'Private',        body: 'Your files are never shared or used for training.' },
      ].map(({ icon, title, body }) => (
        <div class="rounded-xl border border-sonoro-border bg-sonoro-surface p-4">
          <p class="text-xl mb-2">{icon}</p>
          <p class="text-xs font-semibold text-sonoro-900 mb-1">{title}</p>
          <p class="text-xs text-sonoro-muted leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </div>
</DashboardLayout>
