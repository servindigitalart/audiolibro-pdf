---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import UploadZone from '@/components/upload/UploadZone';
---

<DashboardLayout title="Upload PDF – Sonoro" activeNav="upload">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-sonoro-900 tracking-tight mb-1">Upload a PDF</h1>
      <p class="text-sm text-sonoro-muted">
        Drop your file and we'll convert it to a natural-sounding audiobook in seconds.
      </p>
    </div>

    <UploadZone client:load />

    <div class="mt-8 grid grid-cols-3 gap-3">
      {[
        {
          icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>`,
          title: 'Up to 100 MB',
          body:  'Any PDF up to 100 MB and 500 pages.',
        },
        {
          icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd"/></svg>`,
          title: 'Any language',
          body:  'English optimized; other languages supported.',
        },
        {
          icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>`,
          title: 'Private',
          body:  'Your files are never shared or used for training.',
        },
      ].map(({ icon, title, body }) => (
        <div class="rounded-xl border border-sonoro-border bg-sonoro-surface p-4">
          <div class="text-sonoro-amber mb-2.5" set:html={icon} />
          <p class="text-xs font-semibold text-sonoro-900 mb-1">{title}</p>
          <p class="text-xs text-sonoro-muted leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </div>
</DashboardLayout>
