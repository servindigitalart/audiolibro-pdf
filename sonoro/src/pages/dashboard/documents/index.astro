---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import DocumentList from '@/components/dashboard/DocumentList';
import { fetchDocuments } from '@/lib/api/server';
import type { Document } from '@/lib/api/types';

const token = (Astro.locals as any).token as string;

let documents: Document[] = [];
try {
  documents = await fetchDocuments(token);
} catch {
  // handled via empty state in DocumentList
}

const completed  = documents.filter(d => d.status === 'completed').length;
const processing = documents.filter(d => d.status === 'processing' || d.status === 'pending').length;
---

<DashboardLayout title="My Library – Sonoro" activeNav="documents">

  <div class="mb-7 animate-fade-in">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-sonoro-900 tracking-tight mb-1">My Library</h1>
        <p class="text-sm text-sonoro-muted">
          {documents.length === 0
            ? 'Your audiobooks will appear here.'
            : `${documents.length} audiobook${documents.length !== 1 ? 's' : ''}`
              + (completed > 0 ? ` · ${completed} ready` : '')
              + (processing > 0 ? ` · ${processing} processing` : '')}
        </p>
      </div>
      <a href="/dashboard/upload" class="btn-accent btn-sm shrink-0">
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 2v9M4 7l4-4 4 4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Upload PDF
      </a>
    </div>
  </div>

  <div class="animate-fade-in" style="animation-delay:80ms;animation-fill-mode:both">
    <DocumentList initialDocuments={documents} client:load />
  </div>

</DashboardLayout>
