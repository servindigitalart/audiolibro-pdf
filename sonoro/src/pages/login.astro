---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
import LoginForm from '@/components/auth/LoginForm';

// Preserve the intended destination so the Google OAuth link can carry it
// through the redirect dance and land the user back where they were going.
const next = Astro.url.searchParams.get('next') ?? '';
---

<BaseLayout
  title="Sign in – Sonoro"
  description="Sign in to your Sonoro account."
  noIndex={true}
>
  <div class="flex min-h-screen">

    <!-- ── Left — form panel ── -->
    <div class="flex flex-1 flex-col justify-center px-6 py-12 lg:px-12 xl:px-20 relative bg-sonoro-white">
      <!-- Subtle ambient glow -->
      <div
        class="absolute top-0 left-0 w-80 h-80 rounded-full opacity-[0.07] blur-[80px] pointer-events-none"
        style="background: radial-gradient(ellipse, #F59E0B 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto w-full max-w-sm">
        <a href="/" class="flex items-center gap-2.5 mb-10 group w-fit" aria-label="Sonoro home">
          <SonoroLogo class="h-6 w-6" />
          <span class="text-[1.0625rem] font-bold tracking-tight text-sonoro-900 group-hover:text-sonoro-amber transition-colors">Sonoro</span>
        </a>

        <h1 class="text-[1.5rem] font-bold text-sonoro-900 tracking-tight mb-1">Welcome back</h1>
        <p class="text-sm text-sonoro-muted mb-8">Sign in to continue where you left off</p>

        <LoginForm googleNext={next} client:load />

        <p class="mt-7 text-center text-sm text-sonoro-muted">
          No account yet?{' '}
          <a href="/register" class="font-semibold text-sonoro-900 hover:text-sonoro-amber transition-colors">
            Start for free →
          </a>
        </p>
      </div>
    </div>

    <!-- ── Right — brand panel (desktop only) ── -->
    <div class="hidden lg:flex flex-1 flex-col justify-center bg-sonoro-black px-14 py-12 relative overflow-hidden">

      <!-- Animated ambient orbs -->
      <div
        class="absolute top-[-10%] right-[-10%] w-[500px] h-[500px] glow-orb animate-glow-pulse pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(245,158,11,0.20) 0%, rgba(245,158,11,0.04) 50%, transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-[-15%] left-[-10%] w-[400px] h-[400px] glow-orb animate-float-delayed pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(245,158,11,0.10) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <!-- Subtle grid on dark bg -->
      <div
        class="absolute inset-0 pointer-events-none opacity-[0.4]"
        style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 64px 64px;"
        aria-hidden="true"
      ></div>

      <div class="relative z-10">
        <!-- Waveform -->
        <div class="flex items-end gap-1.5 h-16 mb-10" aria-hidden="true">
          {[38, 65, 90, 72, 50, 84, 58, 78, 44, 92].map((h, i) => (
            <div
              class="waveform-bar w-2.5"
              style={`height:${h}%;animation-delay:${i * 0.11}s`}
            ></div>
          ))}
        </div>

        <h2 class="text-[1.875rem] font-bold text-sonoro-white mb-4 leading-tight tracking-tight">
          Turn your reading list<br />into a playlist.
        </h2>
        <p class="text-sonoro-400 text-[0.9375rem] leading-relaxed max-w-xs">
          Over 2,400 students and professionals use Sonoro to consume knowledge on their own schedule.
        </p>

        <!-- Testimonial card -->
        <div class="mt-10 rounded-2xl border border-white/[0.07] bg-white/[0.04] p-5 backdrop-blur-sm">
          <div class="flex gap-0.5 mb-3" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-3.5 h-3.5 text-sonoro-amber" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-sonoro-300 leading-relaxed">
            "I listen to research papers on my commute. Sonoro changed how I consume knowledge."
          </p>
          <p class="text-xs text-sonoro-600 mt-3">— Sarah K., PhD Candidate at MIT</p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
