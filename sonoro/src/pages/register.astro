---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SonoroLogo from '@/components/ui/SonoroLogo.astro';
import RegisterForm from '@/components/auth/RegisterForm';

const plan = Astro.url.searchParams.get('plan') ?? undefined;
---

<BaseLayout
  title="Create account – Sonoro"
  description="Create your free Sonoro account and start converting PDFs to audiobooks."
  noIndex={true}
>
  <div class="flex min-h-screen">

    <!-- ── Left — form panel ── -->
    <div class="flex flex-1 flex-col justify-center px-6 py-12 lg:px-12 xl:px-20 relative bg-sonoro-white">
      <!-- Ambient glow -->
      <div
        class="absolute top-0 left-0 w-80 h-80 rounded-full opacity-[0.07] blur-[80px] pointer-events-none"
        style="background: radial-gradient(ellipse, #F59E0B 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto w-full max-w-sm">
        <a href="/" class="flex items-center gap-2.5 mb-10 group w-fit" aria-label="Sonoro home">
          <SonoroLogo class="h-6 w-6" />
          <span class="text-[1.0625rem] font-bold tracking-tight text-sonoro-900 group-hover:text-sonoro-amber transition-colors">Sonoro</span>
        </a>

        {plan && plan !== 'free' && (
          <div class="mb-6 rounded-xl border border-sonoro-amber/30 bg-sonoro-amber-light/70 px-4 py-3">
            <p class="text-sm font-semibold text-sonoro-amber-dark capitalize">{plan} plan selected</p>
            <p class="text-xs text-sonoro-700 mt-0.5">Create your account to start your 14-day trial.</p>
          </div>
        )}

        <h1 class="text-[1.5rem] font-bold text-sonoro-900 tracking-tight mb-1">Create your account</h1>
        <p class="text-sm text-sonoro-muted mb-8">Free forever · No credit card required</p>

        <RegisterForm initialPlan={plan} client:load />

        <p class="mt-7 text-center text-sm text-sonoro-muted">
          Already have an account?{' '}
          <a href="/login" class="font-semibold text-sonoro-900 hover:text-sonoro-amber transition-colors">
            Sign in →
          </a>
        </p>
      </div>
    </div>

    <!-- ── Right — value prop panel (desktop only) ── -->
    <div class="hidden lg:flex flex-1 flex-col justify-center bg-sonoro-surface border-l border-sonoro-border px-14 py-12 relative overflow-hidden">
      <!-- Subtle ambient orb -->
      <div
        class="absolute bottom-0 right-0 w-[400px] h-[400px] glow-orb opacity-[0.12] animate-float pointer-events-none"
        style="background: radial-gradient(ellipse, #F59E0B 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative z-10">
        <p class="label-sm text-sonoro-amber-dark mb-7">What you get on day one</p>

        <ul class="space-y-5">
          {[
            {
              icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.997.373-1.93 1-2.63A4 4 0 108 11.37c.627.7.985 1.633 1 2.63h3z"/></svg>`,
              title: '5 free conversions',
              body: 'No expiry, no catch. Convert 5 PDFs and keep the audio forever.',
            },
            {
              icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>`,
              title: 'Ready in under 60 seconds',
              body: 'From upload to playback in less time than it takes to make coffee.',
            },
            {
              icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>`,
              title: 'Private by default',
              body: 'Encrypted in transit and at rest. Never used for training. Yours alone.',
            },
            {
              icon: `<svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>`,
              title: 'Listen anywhere',
              body: 'Browser playback or MP3 download. No app required, ever.',
            },
          ].map(({ icon, title, body }) => (
            <li class="flex items-start gap-4">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sonoro-amber-light text-sonoro-amber-dark shrink-0 mt-0.5">
                <Fragment set:html={icon} />
              </div>
              <div>
                <p class="text-sm font-semibold text-sonoro-900">{title}</p>
                <p class="text-sm text-sonoro-600 leading-relaxed mt-0.5">{body}</p>
              </div>
            </li>
          ))}
        </ul>

        <!-- Testimonial -->
        <div class="mt-9 rounded-2xl bg-sonoro-white border border-sonoro-border p-5 shadow-soft">
          <div class="flex gap-0.5 mb-3" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-3.5 h-3.5 text-sonoro-amber" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-sonoro-700 leading-relaxed">
            "Signed up, uploaded a PDF, had an audiobook in under 2 minutes. Genuinely impressive."
          </p>
          <p class="text-xs text-sonoro-muted mt-2">— Marcus R., Strategy Consultant</p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
