# Sonoro API — Production Environment
# =====================================
# Copy to .env.production (or inject via CI secrets) before deploying.
# NEVER commit .env.production — it contains secrets.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-secret

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=sonoro
POSTGRES_PASSWORD=replace-with-very-strong-password
POSTGRES_DB=sonoro_production
DATABASE_URL=postgresql://sonoro:replace-with-very-strong-password@db-host:5432/sonoro_production
DATABASE_ASYNC_URL=postgresql+asyncpg://sonoro:replace-with-very-strong-password@db-host:5432/sonoro_production
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis-host:6379/0
CELERY_BROKER_URL=redis://:replace-with-strong-redis-password@redis-host:6379/1
CELERY_RESULT_BACKEND=redis://:replace-with-strong-redis-password@redis-host:6379/2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_EMAIL_VERIFICATION=true
FEATURE_RATE_LIMITING=true
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_TTS_PROCESSING=true
FEATURE_STRIPE_BILLING=true
FEATURE_ABUSE_DETECTION=true
FEATURE_REQUEST_TRACING=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ── Document Storage ──────────────────────────────────────────────────────────
SPACES_REGION=nyc3
SPACES_BUCKET=sonoro-documents
SPACES_ENDPOINT=
SPACES_ACCESS_KEY=replace-with-spaces-key
SPACES_SECRET_KEY=replace-with-spaces-secret
MAX_UPLOAD_SIZE_MB=50

# ── Google Cloud TTS ──────────────────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=/run/secrets/gcp_credentials
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_PROJECT_ID=your-project-id
GOOGLE_TTS_DEFAULT_VOICE=en-US-Neural2-A
GOOGLE_TTS_DEFAULT_LANGUAGE=en-US

# ── Stripe (live keys in production) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...
BILLING_RETURN_URL=https://yourdomain.com/billing

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/yyy
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
METRICS_COLLECTION_INTERVAL=15

# ── Cost Governance ───────────────────────────────────────────────────────────
HARD_COST_LIMIT_ENABLED=true
GLOBAL_MONTHLY_COST_CAP=10000.0
USER_MONTHLY_COST_CAP=1000.0
EMERGENCY_SHUTDOWN_MODE=false
COST_ALERT_THRESHOLD_PERCENTAGE=80.0

# ── Abuse Detection ───────────────────────────────────────────────────────────
ABUSE_DETECTION_ENABLED=true
ABUSE_CHECK_INTERVAL_MINUTES=15
