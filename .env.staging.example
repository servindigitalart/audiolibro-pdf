# Sonoro API — Staging Environment
# ==================================
# Copy to .env.staging and fill in real values before running docker-compose.staging.yml.
# NEVER commit .env.staging — it contains secrets.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=staging
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://staging.yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-secret

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (staging — separate from dev) ────────────────────────────────────
POSTGRES_USER=sonoro
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=sonoro_staging
DATABASE_URL=postgresql://sonoro:replace-with-strong-password@postgres:5432/sonoro_staging
DATABASE_ASYNC_URL=postgresql+asyncpg://sonoro:replace-with-strong-password@postgres:5432/sonoro_staging
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis (password-protected in staging) ─────────────────────────────────────
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:replace-with-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:replace-with-redis-password@redis:6379/2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_EMAIL_VERIFICATION=false
FEATURE_RATE_LIMITING=true
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_TTS_PROCESSING=true
FEATURE_STRIPE_BILLING=false
FEATURE_ABUSE_DETECTION=true
FEATURE_REQUEST_TRACING=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ── Document Storage ──────────────────────────────────────────────────────────
SPACES_REGION=nyc3
SPACES_BUCKET=sonoro-staging-documents
SPACES_ENDPOINT=
SPACES_ACCESS_KEY=replace-with-spaces-key
SPACES_SECRET_KEY=replace-with-spaces-secret
MAX_UPLOAD_SIZE_MB=50

# ── Google Cloud TTS ──────────────────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_DEFAULT_VOICE=en-US-Neural2-A
GOOGLE_TTS_DEFAULT_LANGUAGE=en-US

# ── Stripe (use test keys in staging) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...
BILLING_RETURN_URL=https://staging.yourdomain.com/billing

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.5
SENTRY_PROFILES_SAMPLE_RATE=0.1
METRICS_COLLECTION_INTERVAL=15

# ── Cost Governance ───────────────────────────────────────────────────────────
HARD_COST_LIMIT_ENABLED=true
GLOBAL_MONTHLY_COST_CAP=500.0
USER_MONTHLY_COST_CAP=50.0
EMERGENCY_SHUTDOWN_MODE=false
COST_ALERT_THRESHOLD_PERCENTAGE=80.0

# ── Abuse Detection ───────────────────────────────────────────────────────────
ABUSE_DETECTION_ENABLED=true
ABUSE_CHECK_INTERVAL_MINUTES=15
