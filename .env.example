# ===========================================
# SONORO — ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.
#
# Railway (API + Worker): set these in the Railway service environment tab.
# Vercel (Frontend): set NEXT_PUBLIC_* vars in the Vercel project settings.

# ============================================
# APPLICATION
# ============================================
APP_ENV=development           # production | development
DEBUG=false                   # MUST be false in production
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# SECURITY — CRITICAL
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins.
# Production: set to your Vercel domain.
API_CORS_ORIGINS=https://your-app.vercel.app

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Railway provides DATABASE_URL automatically when you add a Postgres plugin.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://sonoro:sonoro_dev_password@localhost:5432/sonoro

# Connection pool tuning (defaults are fine for most deployments)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# REDIS
# ============================================
# Railway provides REDIS_URL automatically when you add a Redis plugin.
REDIS_URL=redis://localhost:6379/0

# ============================================
# CELERY
# ============================================
# Broker: Redis (separate DB index from the API cache).
# NOTE: The app uses CELERY_BROKER_URL for both the broker AND result backend.
#       CELERY_RESULT_BACKEND is defined in config but not used by celery_app.py.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# OBJECT STORAGE (DigitalOcean Spaces / S3-compatible)
# ============================================
SPACES_REGION=nyc3
SPACES_BUCKET=sonoro-documents
SPACES_ENDPOINT=               # Auto-generated if empty: https://{region}.digitaloceanspaces.com
SPACES_ACCESS_KEY=             # From DigitalOcean → Spaces → API Keys
SPACES_SECRET_KEY=
MAX_UPLOAD_SIZE_MB=50

# ============================================
# GOOGLE CLOUD TTS
# ============================================
# Option A — service account JSON (path to file, or inline JSON string)
GOOGLE_TTS_CREDENTIALS_JSON=
# Option B — API key (simpler, less granular permissions)
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_DEFAULT_VOICE=en-US-Neural2-A
GOOGLE_TTS_DEFAULT_LANGUAGE=en-US

# ============================================
# STRIPE BILLING
# ============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard → Products
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# Must point to your production frontend domain — NOT localhost
BILLING_RETURN_URL=https://your-app.vercel.app/billing

# ============================================
# COST GOVERNANCE
# ============================================
HARD_COST_LIMIT_ENABLED=false
GLOBAL_MONTHLY_COST_CAP=10000.0
USER_MONTHLY_COST_CAP=1000.0
EMERGENCY_SHUTDOWN_MODE=false
COST_ALERT_THRESHOLD_PERCENTAGE=80.0

# ============================================
# ABUSE DETECTION
# ============================================
ABUSE_DETECTION_ENABLED=true
ABUSE_CHECK_INTERVAL_MINUTES=15

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json (recommended for production) | text

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_EMAIL_VERIFICATION=false
FEATURE_RATE_LIMITING=true

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
SENTRY_DSN=                    # From sentry.io → Settings → Projects → DSN
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
METRICS_COLLECTION_INTERVAL=15

# ============================================
# FRONTEND (Vercel)
# ============================================
# Set these in Vercel dashboard → Project → Settings → Environment Variables.
# For local dev, copy to frontend/.env.local
NEXT_PUBLIC_API_URL=https://your-railway-api.up.railway.app/api/v1
NEXT_PUBLIC_APP_NAME=Sonoro
NEXT_PUBLIC_APP_VERSION=0.9.0

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# 1.  Generate SECRET_KEY:         openssl rand -hex 32
# 2.  Set APP_ENV=production and DEBUG=false
# 3.  Set API_CORS_ORIGINS to your Vercel domain
# 4.  Set BILLING_RETURN_URL to your Vercel domain
# 5.  Use Railway Postgres/Redis plugins — they inject DATABASE_URL and REDIS_URL
# 6.  Set CELERY_BROKER_URL to the same Redis instance (different DB index)
# 7.  Add SPACES_ACCESS_KEY + SPACES_SECRET_KEY (private bucket)
# 8.  Add GOOGLE_TTS_CREDENTIALS_JSON or GOOGLE_TTS_API_KEY
# 9.  Add all STRIPE_* keys and STRIPE_PRICE_* IDs
# 10. Set SENTRY_DSN for production error tracking
# 11. Set FEATURE_RATE_LIMITING=true in production
