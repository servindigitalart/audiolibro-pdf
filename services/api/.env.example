# Sonoro API — Environment Variables Reference
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — it contains secrets.
# Test environment is configured automatically via services/api/conftest.py
#   (uses os.environ.setdefault so CI / Docker env vars always take precedence).

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | test | staging | production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-real-64-char-hex-secret

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sonoro
DATABASE_ASYNC_URL=postgresql+asyncpg://user:password@localhost:5432/sonoro
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | text

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
FEATURE_RATE_LIMITING=false  # set true to activate Redis-backed rate limiting

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_EMAIL_VERIFICATION=false

# ── Document Storage (DigitalOcean Spaces / S3-compatible) ───────────────────
SPACES_REGION=nyc3
SPACES_BUCKET=sonoro-documents
SPACES_ENDPOINT=
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
MAX_UPLOAD_SIZE_MB=50

# ── Google Cloud TTS ──────────────────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_DEFAULT_VOICE=en-US-Neural2-A
GOOGLE_TTS_DEFAULT_LANGUAGE=en-US

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...
BILLING_RETURN_URL=http://localhost:3000/billing

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
METRICS_COLLECTION_INTERVAL=15

# ── Cost Governance ───────────────────────────────────────────────────────────
HARD_COST_LIMIT_ENABLED=false
GLOBAL_MONTHLY_COST_CAP=10000.0
USER_MONTHLY_COST_CAP=1000.0
EMERGENCY_SHUTDOWN_MODE=false
COST_ALERT_THRESHOLD_PERCENTAGE=80.0

# ── Abuse Detection ───────────────────────────────────────────────────────────
ABUSE_DETECTION_ENABLED=true
ABUSE_CHECK_INTERVAL_MINUTES=15
