# ============================================
# FRONTEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development.
# For production (Vercel): set these in the Vercel dashboard →
#   Project → Settings → Environment Variables
#
# All NEXT_PUBLIC_* vars are embedded into the client bundle at build time.
# Changing them requires a redeploy.

# URL of the deployed Railway API — no trailing slash
# Local dev:  http://localhost:8000/api/v1
# Production: https://your-api.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app/api/v1

NEXT_PUBLIC_APP_NAME=Sonoro
NEXT_PUBLIC_APP_VERSION=0.9.0
